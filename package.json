{
  "name": "goodgame-railway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Railway-ready GoodGame host that serves the current repository content.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js",
    "health": "node -e \"fetch('http://127.0.0.1:'+(process.env.PORT||3000)+'/healthz').then(r=>{if(!r.ok)process.exit(1);return r.text()}).then(console.log)\""
  }
}
