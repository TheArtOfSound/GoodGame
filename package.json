{
  "name": "goodgame-center",
  "version": "0.1.0",
  "private": true,
  "description": "GoodGame.center — instant browser arcade and creator upload lab.",
  "scripts": {
    "dev": "pnpm --filter web run dev",
    "deploy": "pnpm --filter web run deploy",
    "seo:crawl": "python3 scripts/seo_crawl.py --base https://goodgame.center --output reports/seo-crawl.json",
    "db:migrate:local": "pnpm --filter web run db:migrate:local",
    "db:migrate:remote": "pnpm --filter web run db:migrate:remote",
    "db:seed:local": "pnpm --filter web run db:seed:local",
    "db:seed:remote": "pnpm --filter web run db:seed:remote"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4"
}
